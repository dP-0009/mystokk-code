{
  "expo": {
    "name": "MyStokk",
    "slug": "mystokk",
    "version": "1.0.0",
    "scheme": "mystokk",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecozoe.mystokk",
      "buildNumber": "3",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:www.mystokk.com",
        "applinks:mystokk.com"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ecozoe.mystokk",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.mystokk.com",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "www.mystokk.com",
              "pathPrefix": "/s"
            },
            {
              "scheme": "https",
              "host": "mystokk.com",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "mystokk.com",
              "pathPrefix": "/s"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "MyStokk needs access to your photos to add product images and your company logo.",
          "cameraPermission": "MyStokk needs access to your camera to photograph inventory items.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-font",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "37a9d640-95bd-45ae-9b01-7adf487b56ac"
      }
    },
    "owner": "qliqs-organization"
  }
}
