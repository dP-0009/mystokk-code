# Normalize line endings: store everything as LF in the repo, check out native.
# Prevents CRLF/LF churn across machines (the warnings you saw on Windows).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.docx binary
*.pdf binary
